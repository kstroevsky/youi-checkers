{
  "name": "youi",
  "private": true,
  "version": "0.3.3",
  "type": "module",
  "scripts": {
    "ai:crossplay": "tsx scripts/ai-crossplay.report.ts",
    "ai:crossplay:compare": "node scripts/run-git-report-compare.mjs --pipeline=ai-crossplay",
    "ai:loop-benchmark": "tsx scripts/ai-loop-benchmark.report.ts",
    "ai:loop-benchmark:compare": "node scripts/run-git-report-compare.mjs --pipeline=ai-loop-benchmark",
    "ai:position-buckets": "tsx scripts/ai-position-buckets.report.ts",
    "ai:position-buckets:compare": "node scripts/run-git-report-compare.mjs --pipeline=ai-position-buckets",
    "ai:selfplay": "tsx scripts/ai-selfplay-dataset.ts",
    "ai:stage-variety": "tsx scripts/ai-stage-variety.report.ts",
    "ai:stage-variety:compare": "node scripts/run-git-report-compare.mjs --pipeline=ai-stage-variety",
    "ai:threat": "tsx scripts/ai-threat.report.ts",
    "ai:threat:compare": "node scripts/run-git-report-compare.mjs --pipeline=ai-threat",
    "ai:variety": "tsx scripts/ai-variety.report.ts",
    "ai:variety:compare": "node scripts/run-git-report-compare.mjs --pipeline=ai-variety",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "docs:check-links": "node scripts/check-markdown-links.mjs",
    "preview": "pnpm run build && wrangler dev",
    "perf:charts": "node scripts/perf-charts.mjs",
    "perf:compare": "node scripts/compare-perf-reports.mjs",
    "perf:compare:git": "node scripts/run-git-report-compare.mjs --pipeline=perf-report",
    "perf:report": "npm run build && node scripts/perf-report.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "format": "prettier --check .",
    "deploy": "pnpm run build && wrangler deploy"
  },
  "dependencies": {
    "onnxruntime-web": "^1.23.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.81.0"
  }
}
